@page
@model HospitalAppointment.Pages.Patient.MyAppointmentsModel
@{
    ViewData["Title"] = "Saját Időpontjaim";
}

<h1>Saját Időpontjaim</h1>
<hr />

@if (Model.Appointments != null && Model.Appointments.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Dátum</th>
                <th>Időtartam</th>
                <th>Orvos</th>
                <th>Szakterület</th>
                <th>Státusz</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Appointments)
            {
                <tr>
                    <td>@item.StartTime.ToString("yyyy. MM. dd.")</td>
                    <td>@item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")</td>
                    <td>@item.Doctor.FullName</td>
                    <td>@item.Doctor.Specialty</td>
                    <td>
                        @switch (item.Status)
                        {
                            case HospitalAppointment.Models.AppointmentStatus.Pending:
                                <span class="badge bg-warning text-dark">Függőben</span>
                                break;
                            case HospitalAppointment.Models.AppointmentStatus.Confirmed:
                                <span class="badge bg-success">Jóváhagyva</span>
                                break;
                            case HospitalAppointment.Models.AppointmentStatus.Completed:
                                <span class="badge bg-info text-dark">Befejezve</span>
                                break;
                            case HospitalAppointment.Models.AppointmentStatus.Cancelled:
                                <span class="badge bg-danger">Lemondva</span>
                                break;
                        }

                        @if (item.StartTime > DateTime.Now &&
                                        (item.Status == HospitalAppointment.Models.AppointmentStatus.Pending ||
                                        item.Status == HospitalAppointment.Models.AppointmentStatus.Confirmed))
                        {
                            <form method="post" asp-page-handler="Cancel" asp-route-id="@item.Id" class="d-inline ms-2">
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Biztosan lemondod az időpontot? Ezt a műveletet nem lehet visszavonni.');">
                                    Lemondás
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">Jelenleg nincs egyetlen lefoglalt időpontod sem.</div>
}